{% if site.teachings %}
  <div class="courses">
    {% assign sorted_courses = site.teachings | sort: 'title' %}
    
    {% for course in sorted_courses %}
      <div class="course-item mb-5">
        
        <div class="d-flex justify-content-between align-items-center">
          <h3 class="course-title" style="margin-bottom: 0;">
            {{ course.title }}
          </h3>
          
          <div class="course-years">
            {% for entry in course.years %}
              <span class="badge badge-outline-secondary" 
                    style="border: 1px solid #ccc; font-weight: 400; padding: 4px 8px; font-size: 0.8rem;">
                {{ entry.term }} {{ entry.year }}
              </span>
            {% endfor %}
          </div>
        </div>

        {% if course.description %}
          <div class="course-description mt-3">
            {{ course.description | markdownify }}
          </div>
        {% endif %}

        <hr class="course-divider">
      </div>
    {% endfor %}
  </div>
{% else %}
  <p>No courses available yet.</p>
{% endif %}
